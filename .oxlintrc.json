{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": ["playground/**/*"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "rules": {
    "unicorn/no-useless-spread": "off",
    "eslint/no-unused-vars": "error"
  },
  "env": {
    "builtin": true
  }
}
